{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "public": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1.php" },
    { "source": "/(.*)", "destination": "/frontend/dist/$1" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/frontend/dist/index.html" }
  ]
}